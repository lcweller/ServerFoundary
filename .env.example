# Public URL where the dashboard is reachable (used by the install script).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL the agent should use to reach the WebSocket server (separate
# from the dashboard port). In production, put a reverse proxy in front and
# set this to, e.g., wss://your-domain/ws.
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:3001

# PostgreSQL connection string.
DATABASE_URL=postgres://gameserveros:gameserveros@localhost:5432/gameserveros

# Port on which the agent WebSocket server listens (separate from Next.js).
AGENT_WS_PORT=3001

# Shared secret used by the Next.js process to deliver agent-bound commands
# via the ws-server /internal/dispatch HTTP endpoint. Must match across
# both processes.
INTERNAL_API_KEY=change-me-in-production-to-a-long-random-string

# External TCP relay (ADR 0001 Option A) — the platform listens on ports
# [EXTERNAL_PORT_START, EXTERNAL_PORT_START + EXTERNAL_PORT_COUNT - 1] and
# forwards each connection to the right agent over the existing WS. The
# operator must port-forward this range on their router.
EXTERNAL_PORT_START=30000
EXTERNAL_PORT_COUNT=100

# Hostname players dial to reach hosted game servers. Defaults to the host
# part of NEXT_PUBLIC_APP_URL. Set explicitly if the relay listens on a
# different subdomain than the dashboard.
# RELAY_PUBLIC_HOSTNAME=game.layeroneconsultants.com
